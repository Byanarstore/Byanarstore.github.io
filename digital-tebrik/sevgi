<!DOCTYPE html>
<html lang="az">
<head>
<meta charset="UTF-8">
<title>Sevgi 🌙🌸</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:'Poppins',sans-serif;
}

body{
  height:100vh;
  overflow:hidden;
  background: radial-gradient(circle at top, #1a1a1a, #000);
  color:white;
}

/* animated bg */
.bg{
  position:fixed;
  width:200%;
  height:200%;
  background: linear-gradient(45deg,#ff004c,#ff7a00,#ffd000,#00ffcc,#0066ff,#cc00ff);
  animation: move 12s linear infinite;
  filter: blur(120px);
  opacity:0.3;
}

@keyframes move{
  0%{transform:translate(0,0);}
  50%{transform:translate(-50%,-50%);}
  100%{transform:translate(0,0);}
}

/* scenes */
.scene{
  position:absolute;
  width:100%;
  height:100%;
  display:flex;
  justify-content:center;
  align-items:center;
  opacity:0;
  pointer-events:none;
  transform:scale(0.9);
  transition:0.6s;
}

.scene.active{
  opacity:1;
  pointer-events:auto;
  transform:scale(1);
}

/* card */
.card{
  backdrop-filter: blur(20px);
  background: rgba(255,255,255,0.08);
  border-radius:20px;
  padding:30px;
  box-shadow:0 0 40px rgba(255,0,100,0.3);
  text-align:center;
}

/* button */
.btn{
  margin-top:20px;
  padding:12px 25px;
  border-radius:30px;
  border:none;
  background:linear-gradient(45deg,#ff004c,#ff7a00);
  color:white;
  font-size:16px;
  cursor:pointer;
  transition:0.3s;
}

.btn:hover{
  transform:scale(1.1);
}

/* title */
.title{
  font-size:26px;
  background:linear-gradient(90deg,#fff,#ff7a00,#ff004c);
  -webkit-background-clip:text;
  color:transparent;
}

/* scratch container */
.scratch-box{
  position: relative;
  width: 280px;
  height: 140px;
  margin: 15px auto;
}

.scratch-text{
  position:absolute;
  width:100%;
  height:100%;
  display:flex;
  justify-content:center;
  align-items:center;
  text-align:center;
  z-index:1;
  padding:10px;
}

#scratch{
  position:absolute;
  top:0;
  left:0;
  z-index:2;
  border-radius:15px;
}

/* hearts */
.heart{
  position:fixed;
  font-size:18px;
  animation:float 6s linear infinite;
}

@keyframes float{
  from{transform:translateY(100vh);}
  to{transform:translateY(-10vh);}
}

/* confetti */
.confetti{
  position:fixed;
  width:6px;
  height:6px;
  background:gold;
  animation:fall 3s linear infinite;
}

@keyframes fall{
  from{transform:translateY(-10vh);}
  to{transform:translateY(100vh);}
}
</style>
</head>

<body>

<div class="bg"></div>

<!-- SCENE 1 -->
<div class="scene active" id="s1">
  <div class="card">
    <h1 class="title">Səninlə hər şey başladı ❤️</h1>
    <p>Bu sadəcə ekran deyil... bu hissdir</p>
    <button class="btn" onclick="go(2)">Başla</button>
  </div>
</div>

<!-- SCENE 2 SCRATCH -->
<div class="scene" id="s2">
  <div class="card">
    <h2 class="title">Sevgini tap ✨</h2>

    <div class="scratch-box">
      <p class="scratch-text">Sən mənim həyatımın ən gözəl hissəsisən 💖</p>
      <canvas id="scratch" width="280" height="140"></canvas>
    </div>

    <button class="btn" onclick="go(3)">Davam</button>
  </div>
</div>

<!-- SCENE 3 -->
<div class="scene" id="s3">
  <div class="card">
    <h2 class="title">Bir sual ❤️</h2>
    <p>Mən səni nə qədər sevirəm?</p>
    <input id="a" placeholder="Cavab..." style="padding:10px;border-radius:10px;border:none;">
    <br>
    <button class="btn" onclick="check()">Cavabla</button>
    <p id="r"></p>
    <button class="btn" onclick="go(4)">Keç</button>
  </div>
</div>

<!-- SCENE 4 -->
<div class="scene" id="s4">
  <div class="card">
    <h2 class="title">Xatirələrimiz 🌙</h2>
    <div id="mem"></div>
    <button class="btn" onclick="go(5)">Final</button>
  </div>
</div>

<!-- FINAL -->
<div class="scene" id="s5">
  <div class="card">
    <h1 class="title">Səni sevirəm ❤️</h1>
    <h2 class="title">Novruz & Ramazan Bayramın Mübarək 🌙🌸</h2>
    <p>Hər gün səninlə bayramdır...</p>
    <button class="btn" onclick="go(1)">Yenidən</button>
  </div>
</div>

<script>
// scene
function go(n){
  document.querySelectorAll(".scene").forEach(s=>s.classList.remove("active"));
  document.getElementById("s"+n).classList.add("active");

  if(n==5) confetti();
}

// hearts
setInterval(()=>{
  let h=document.createElement("div");
  h.className="heart";
  h.innerHTML="❤️";
  h.style.left=Math.random()*100+"vw";
  document.body.appendChild(h);
  setTimeout(()=>h.remove(),6000);
},400);

// SCRATCH REAL EFFECT
let canvas=document.getElementById("scratch");
let ctx=canvas.getContext("2d");

// boz layer
ctx.fillStyle="#999";
ctx.fillRect(0,0,280,140);

// tekstura (real effekt)
for(let i=0;i<2000;i++){
  ctx.fillStyle="rgba(255,255,255,0.05)";
  ctx.fillRect(Math.random()*280, Math.random()*140, 2,2);
}

ctx.globalCompositeOperation="destination-out";

let draw=false;

canvas.addEventListener("mousedown",()=>draw=true);
canvas.addEventListener("mouseup",()=>draw=false);

canvas.addEventListener("mousemove",(e)=>{
  if(!draw)return;
  let r=canvas.getBoundingClientRect();
  let x=e.clientX-r.left;
  let y=e.clientY-r.top;

  ctx.beginPath();
  ctx.arc(x,y,15,0,Math.PI*2);
  ctx.fill();
});

// answer
function check(){
  let v=document.getElementById("a").value.toLowerCase();
  document.getElementById("r").innerHTML =
    v=="sonsuz" ? "Doğru ❤️" : "Daha çox 😄";
}

// memories
let arr=["İlk baxış ❤️","Gülüşün 😍","Mesajlarımız 💬","Gəzinti 🔆","Sarılmaq 🤍","Sən 💖"];
let m=document.getElementById("mem");

arr.forEach(t=>{
  let d=document.createElement("div");
  d.innerText="❓";
  d.style.cssText="display:inline-block;margin:5px;padding:15px;background:#222;border-radius:10px;cursor:pointer;";
  d.onclick=()=>{
    d.innerText=t;
    d.style.background="crimson";
  }
  m.appendChild(d);
});

// confetti
function confetti(){
  setInterval(()=>{
    let c=document.createElement("div");
    c.className="confetti";
    c.style.left=Math.random()*100+"vw";
    document.body.appendChild(c);
    setTimeout(()=>c.remove(),3000);
  },150);
}
</script>

</body>
</html>
